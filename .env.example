# Copy to .env and fill values. Never commit .env.

APP_ENV=development
HTTP_PORT=8080

# PostgreSQL DSN (use docker-compose or your host)
DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable

# HS256 signing secret — min 32 chars; rotate via secret manager in production
JWT_SECRET=change-me-use-at-least-32-characters-long-secret
JWT_EXPIRY_MINUTES=60

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Token bucket per IP (in-memory; use Redis limiter when scaling horizontally)
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
